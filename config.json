        "index documents": {
            "exercice": {
                "folder name": "exercices",
                "name pattern": "-(\\d{4})-(data|[a-z])\\.([A-Za-z\\.]+)$"
            },
            "activite": {
                "folder name": "activites",
                "name pattern": "-([A-Za-z_\\d]+)-(\\d+)\\.([A-Za-z\\.]+)$"
            },
            "flash": {
                "folder name": "flash",
                "name pattern": "-([A-Za-z_\\d]+)-(\\d+)\\.([A-Za-z\\.]+)$"
            },
            "diapo": {
                "folder name": "diapo",
                "name pattern": "-([A-Za-z_\\d]+)-(\\d+)\\.([A-Za-z\\.]+)$"
            },
            "dnbqcm": {
                "folder name": "dnbqcm",
                "name pattern": "-(\\d{4})\\.([A-Za-z\\.]+)$"
            }
        },
        "ignored extensions": [
            ".aux",
            ".log",
            ".fls",
            ".fdb_latexmk",
