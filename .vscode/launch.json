{
    "version": "0.2.0",
    "configurations": [
        {
        "name": "Run src.tools module",
        "type": "debugpy",
        "request": "launch",
        "module": "src.${fileBasenameNoExtension}",
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal",
        "justMyCode": true
        },
        {
            "name": "Launch Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}