{
    "files.exclude": {
        "output/2021-2022": true,
        "output/2022-2023": true,
        "output/2023-2024": true,
        "output/2024-2025": true,
        "output/2025-2026/**/*.!(pdf)": true,
        "data/latex/**/*.pdf":true,
        "data/latex/**/*.log":true,
        "data/latex/**/*.aux":true,
        "data/latex/**/*.out":true,
        "data/latex/**/*.toc":true,
        "data/latex/**/*.snm":true,
        "data/latex/**/*.nav":true,
        "data/latex/**/*.txt":true,
        "data/latex/**/*.synctex.gz":true,
        "data/latex/**/*.fdb_latexmk":true,
        "data/latex/**/*.fls":true,
        "*.toml": true,
        "*.txt": false
    },
    "terminal.integrated.cwd": "${workspaceFolder}",
    "python.analysis.extraPaths": ["./src"],
    "python-envs.pythonProjects": [
      {
        "path": ".",
        "envManager": "ms-python.python:system",
        "packageManager": "ms-python.python:pip"
      }
    ],
    "latex-workshop.latex.tools": [
      {
      "name": "lualatex-linux",
      "command": "lualatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-shell-escape",
        "%DOC%"
      ]
    },
    {
      "name": "miktex-pdflatex",
      "command": "\\Root\\Programmes\\MiKTeX\\texmfs\\install\\miktex\\bin\\x64\\miktex-pdflatex.exe",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-shell-escape",
        "%DOC%"
      ]
    },{
      "name": "lualatex",
      "command": "\\Root\\Programmes\\MiKTeX\\texmfs\\install\\miktex\\bin\\x64\\lualatex.exe",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-shell-escape",
        "%DOC%"
      ]
    },
    {
      "name": "pdflatex-nopdf",
      "command": "\\Root\\Programmes\\MiKTeX\\texmfs\\install\\miktex\\bin\\x64\\miktex-pdflatex.exe",
      "args": [
        "-halt-on-error",
        "-draftmode",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "LuaLaTeX (Linux)",
      "tools": [
        "lualatex-linux"
      ]
    },
    {
      "name": "pdfLaTeX (portable)",
      "tools": [
        "miktex-pdflatex"
      ]
    },{
      "name": "LuaLaTeX (portable)",
      "tools": [
        "lualatex"
      ]
    },
    {
      "name": "pdfLaTeX (test)",
      "tools": [
        "pdflatex-nopdf"
      ]
    }
  ],
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.autoBuild.run": "never"
}