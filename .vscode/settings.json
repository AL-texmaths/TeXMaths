{
    "files.exclude": {
        "output/2021-2022": true,
        "output/2022-2023": true,
        "output/2023-2024": true,
        "output/2024-2025": true,
        "output/2025-2026/**/*.!(pdf)": true,
        "data/latex/**/*.pdf":true,
        "data/latex/**/*.log":true,
        "data/latex/**/*.aux":true,
        "data/latex/**/*.out":true,
        "data/latex/**/*.toc":true,
        "data/latex/**/*.snm":true,
        "data/latex/**/*.nav":true,
        "data/latex/**/*.txt":true,
        "data/latex/**/*.synctex.gz":true,
        "data/latex/**/*.fdb_latexmk":true,
        "data/latex/**/*.fls":true,
        "*.toml": true,
        "*.txt": false,
    },
    "terminal.integrated.cwd": "${workspaceFolder}",
    "python.analysis.extraPaths": ["./src", "./src_ap"],
    "env": {
        "TEXMATHS": "${workspaceFolder}"
    },
    "latex-workshop.latex.tools": [
      {
        "name": "latexmk-pc",
        "command": "latexmk",
        "args": [
          "-lualatex",
          "-synctex=1",
          "-interaction=nonstopmode",
          "-file-line-error",
          "-shell-escape",
          "-recorder",
          "%DOCFILE%"
        ]
      },
      {
        "name": "latexmk-portable",
        "command": "\\Root\\Programmes\\MiKTeX\\texmfs\\install\\miktex\\bin\\x64\\latexmk.exe",
        "args": [
          "-lualatex",
          "-synctex=1",
          "-interaction=nonstopmode",
          "-file-line-error",
          "-shell-escape",
          "-recorder",
          "%DOCFILE%"
        ]
      },
      {
      "name": "lualatex-pc",
      "command": "lualatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-shell-escape",
        "%DOCFILE%"
      ]
    },
    {
      "name": "lualatex-portable",
      "command": "\\Root\\Programmes\\MiKTeX\\texmfs\\install\\miktex\\bin\\x64\\lualatex.exe",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-shell-escape",
        "%DOCFILE%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (PC)",
      "tools": [
        "latexmk-pc"
      ]
    },
    {
      "name": "latexmk (portable)",
      "tools": [
        "latexmk-portable"
      ]
    },
    {
      "name": "LuaLaTeX (PC)",
      "tools": [
        "lualatex-shell"
      ]
    },
    {
      "name": "LuaLaTeX (portable)",
      "tools": [
        "lualatex-portable"
      ]
    }
  ],
  "latex-workshop.latex.recipe.default": "lastUsed",
  "latex-workshop.latex.autoBuild.run": "never",
  "python-envs.pythonProjects": [
    {
      "path": ".",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    }
  ]
}