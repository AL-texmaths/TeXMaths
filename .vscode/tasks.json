{
    "tasks": [
        {
            "label": "Compiler les PDF manquants",
            "type": "shell",
            "command": "find ${input:findArgs} | while read -r tex; do pdf=\"${tex%.tex}.pdf\"; [ -e \"$pdf\" ] || latexmk -pdf \"$tex\"; done",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "bash",
                    "args": ["-c"]
                }
            },
            "problemMatcher": []
        },
        {
            "label": "split main",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "src.mainsplit"
            ],
            "windows": {
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "group": "build"
        },
        {
            "label": "export examples",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "src.export_exemple"
            ],
            "windows": {
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "group": "build"
        },
        {
            "label": "split main + export examples",
            "dependsOn": [
                "split main",
                "export examples"
            ],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "write enonces catalogue",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "src.enonces_catalogue"
            ],
            "windows": {
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build"
        },
        {
            "label": "compile feuilles de suivi",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "src.compile_suivi",
                "${input:classes}"
            ],
            "windows": {
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build"
        },
        {
            "label": "init probas for class",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "src.init_class_probalities",
                "${input:classes}"
            ],
            "windows": {
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build"
        },
        {
            "label": "display stduents notes",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "src.display_students_notes",
                "${input:classes}"
            ],
            "windows": {
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build"
        },
        {
            "label": "make new doc",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "src.make_new_doc"
            ],
            "windows": {
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build"
        },
        {
            "label": "print pdf",
            "type": "process",
            "command": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "src.printer"
            ],
            "windows": {
                "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build"
        },
        {
            "label": "open BO 2026",
            "type": "shell",
            "command": "code",
            "args": [
                "-r", 
                "${workspaceFolder}/data/latex/codes_labels/BO_2026.pdf"
            ],
            "windows": {
                "command": "\\Root\\Programmes\\VSCode\\code.exe"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "open Programmes Cycle 3 BO 2026",
            "type": "shell",
            "command": "code",
            "args": [
                "-r", 
                "/Documents/Officiel/BO_2026/Cycle3_programmes.pdf"
            ],
            "windows": {
                "command": "\\Root\\Programmes\\VSCode\\code.exe"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "open Programmes Cycle 4 BO 2026",
            "type": "shell",
            "command": "code -r ",
            "args": [
                "-r", 
                "/Documents/Officiel/BO_2026/Cycle4_programmes.pdf"
            ],
            "windows": {
                "command": "\\Root\\Programmes\\VSCode\\code.exe"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "open sources",
            "type": "shell",
            "command": "code",
            "args": [
                "-r", 
                "${workspaceFolder}/data/latex/codes_labels/Sources.pdf"
            ],
            "windows": {
                "command": "\\Root\\Programmes\\VSCode\\code.exe"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "open exercice id",
            "type": "shell",
            "command": "code",
            "args": [
                "-r", 
                    "${workspaceFolder}/data/latex/exercices/exercice-${input:exerciceID}-data.tex"
                ],
            "windows": {
                "command": "\\Root\\Programmes\\VSCode\\code.exe"
            },
            "problemMatcher": [],
            "group": "build"
        }
    ],
    "inputs": [
        {
            "id": "dirpath",
            "type": "promptString",
            "description": "Entrez le nom du dossier : ",
        },
        {
            "id": "classes",
            "type": "promptString",
            "description": "Entrez les classes (a separer avec virgule) :"
        },
        {
            "id": "texfilestocompile",
            "type": "promptString",
            "description": "Entrez le nom des fichiers à compiler (regex)"
        },
        {
            "id": "exerciceID",
            "type": "promptString",
            "description": "Entrez l'ID de l'exercice à ouvrir"
        }
    ],
    "version": "2.0.0"
}
