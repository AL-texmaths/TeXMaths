\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texmaths-pytools}[08/03/2026]

\RequirePackage{luacode}

\makeatletter
\def\run@python#1{%
    \directlua{
        local path = os.getenv("PWD"):gsub("\\", "/")
        local root = path:match("(.*/TeXMaths/)")

        if root then
            local project_root = root

            local base = root .. ".venv/"
            local candidates = {
                base .. "Scripts/python.exe",
                base .. "Scripts/python",
                base .. "bin/python",
                base .. "python.exe",
                base .. "python"
            }

            local found
            for _, p in ipairs(candidates) do
                local f = io.open(p, "rb")
                if f then f:close(); found = p; break end
            end

            if found then
                local arg = "#1"

                local cmd = "cd " .. project_root ..
                            " && " .. found ..
                            " " .. arg

                print("")
                print("=== Start Python ===")
                print("Executing: " .. cmd)
                os.execute(cmd)
                print("=== End Python ===")
            end
        end
    }%
}
\makeatother