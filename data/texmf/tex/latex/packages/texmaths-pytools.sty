\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texmaths-pytools}[08/03/2026]

\RequirePackage{luacode}

\makeatletter
\def\run@python#1{%
    \directlua{
        local path = status.filename
        path = path:gsub("\\", "/")
        local root = path:match("(.*/Projects/)")
        local project_root = root .. "TeXMaths/"
        if root then
            local base = root .. "TeXMaths/.venv/"
            local candidates = {
            base .. "Scripts/python.exe",
            base .. "Scripts/python",
            base .. "bin/python",
            base .. "python.exe",
            base .. "python"
            }
            local found = nil
            for _, p in ipairs(candidates) do
            local f = io.open(p, "rb")
            if f then
                f:close()
                found = p
                break
            end
            end
            if found then
                os.execute("cd " .. project_root .. " && " .. found .. " " .. "#1")
            end
        end
    }%
}
\makeatother