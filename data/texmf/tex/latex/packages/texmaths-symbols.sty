\RequirePackage[np]{numprint}%               \np commande for numbers
\RequirePackage{pifont}%                     \ding{210}
\RequirePackage{bbding}%                     \Plane
\RequirePackage{iftex}%                      \ifLuaTeX, \ifXeTeX
\ifLuaTeX
  \RequirePackage{fontspec}%                 fontspec pour les polices OpenDyslexic
  % definition de la police OpenDyslexic
  \newfontfamily\opendyslexic{OpenDyslexic}
  \newcommand\dysfont{\opendyslexic\small}
