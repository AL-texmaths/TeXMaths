    \stepcounter{fourthcycle@boB@aut}
    \deftoks{AUT\Alph{fourthcycle@boB@theme}\arabic{fourthcycle@boB@level}\alph{fourthcycle@boB@subtheme}\alph{fourthcycle@boB@aut}occ}
