    \edef\tmpkey{\Alph{fourthcycle@boB@theme}\arabic{fourthcycle@boB@level}\alph{fourthcycle@boB@subtheme}\alph{fourthcycle@boB@aut}}
    \defunivar\fourthcycle@aut[\tmpkey]{#1}%
	\immediate\write\datafile{aut|:|\tmpkey|:|\unexpanded{#1}}%
    }
\def\newobj#1{
    \stepcounter{fourthcycle@boB@obj}
    \deftoks{OBJ\Alph{fourthcycle@boB@theme}\arabic{fourthcycle@boB@level}\alph{fourthcycle@boB@subtheme}\alph{fourthcycle@boB@obj}occ}
