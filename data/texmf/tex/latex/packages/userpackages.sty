\newcounter{programme}

\def\programmeDef#1#2#3{%
    \stepcounter{programme}
    \begin{minipage}[t]{.45\linewidth}
        \begin{programme}
            \textbf{\color{#1!40!black}Programme \arabic{programme}:}
            \begin{enumerate}[label=\textcolor{#1!40!black}{$\bullet$}, leftmargin=*]
                \item Choisir un nombre.
                \item #2
                \item #3
            \end{enumerate}
        \end{programme}
    \end{minipage}
}

