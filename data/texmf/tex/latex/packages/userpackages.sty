\makeatletter
\newcommand\ifnumber[1]{%
        \begingroup
        \edef\temp{#1}%
        \expandafter\ifstrempty\expandafter{\temp}
                {\endgroup\@secondoftwo}
                {\expandafter\ifnumber@i\temp\@nnil}%
}
\def\ifnumber@i#1#2\@nnil{%
        \if-#1%
                \ifstrempty{#2}
                        {\def\temp{X}}
                        {\def\temp{#2}}%
        \else
                \def\temp{#1#2}%
        \fi
        \afterassignment\ifnumhelper
        \count@0\temp\relax\@nnil
        \endgroup
}

\def\numrelax{\relax}%
\def\ifnumhelper#1\@nnil{%
        \def\temp{#1}%
        \ifx\temp\numrelax
                \aftergroup\@firstoftwo
        \else
                \aftergroup\@secondoftwo
        \fi
}
\def\relatif#1{%
\ifnum#1<0\relax
    (#1)
\else
    #1
\fi}

\makeatother

\def\carreentier#1{%
    \begin{calculs}{cccc}
        =&&#1^2&\\
        =&#1&\times&#1\\
        =&&\number\numexpr#1*#1\relax&
    \end{calculs}
}

\def\novirgules#1,#2;{#1#2}
\def\addvirgule#1#2#3#4{#1#2,#3#4}

\def\carre#1{%
    \begin{calculs}{cccc}
        &&#1^2&\\
        =&#1&\times&#1\\
        =&&\expandafter\addvirgule\number\numexpr\novirgules#1;*\novirgules#1;\relax&
    \end{calculs}
}

\def\num#1{\ifnumber{#1}{\makeatletter\relatif{#1}\makeatother}{\textbf{#1}}}

