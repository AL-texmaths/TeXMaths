\def\funcFromMaths[#1][#2]#3=#4;{
    \global\edef\@funcFromMahts@funcname{#3}
    \tracinglostchars=0\relax
    \begin{axis}[
        x=1cm, y=1cm,
        axis lines=left,
        axis lines=middle,
        legend style={
            at={(0,1.05)},    % 0.5 = centre en x, 1.05 = un peu au-dessus
            anchor=south west,       % ancre la légende sur son bord inférieur
            % draw=none,          % pas de cadre si tu veux
            fill=\maintblrbgcolor
        },
        tick style={thick,black},
        #1
    ]
        \addplot [
            samples=100,
            line width=1.25pt,
            #2
        ]
        {#4};
        \addlegendentry{$y=#3(x)$}
    \end{axis}}
\def\simpleFunc xmin=#1,xmax=#2,ymin=#3,ymax=#4,gridstep=#5,func=#6;{
    \draw[gray,step=#5](0,0)grid(#2-#1,#4-#3);
    \funcFromMaths[xmin=#1*0.999,xmax=#2*0.999,ymin=#3*0.999,ymax=#4*0.999][domain=#1:#2]#6;
    \draw node[right] at(#2-#1,-#3){$x$};
    \draw node[above] at(-#1,#4-#3){$y$};
}
