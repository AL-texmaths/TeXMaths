\def\triangle@angles#1{%
    \pgfkeys{/tikzvariables/.cd,#1}\tiny
    \coordinate[label=\exercice@tikz@variables@Alabelpos:\exercice@tikz@variables@A](A)at(\exercice@tikz@variables@point);
    \coordinate[label=\exercice@tikz@variables@Blabelpos:\exercice@tikz@variables@B](B)at(\exercice@tikz@variables@base,0);
    \path(A)--(B)([turn]\exercice@tikz@variables@angleb:1)coordinate(C1);
    \path(B)--(A)([turn]-\exercice@tikz@variables@anglea:1)coordinate(C2);
    \coordinate[label=\exercice@tikz@variables@Clabelpos:\exercice@tikz@variables@C](C)at (intersection of B--C1 and A--C2);
    \ifx\exercice@tikz@variables@showangles\@true
        \tkzFillAngle[size=0.6,mark=none,fill=\currentcolor](C,A,B)
        \tkzFillAngle[size=0.6,mark=none,fill=\currentcolor](A,B,C)
        \tkzLabelAngle[pos=\exercice@tikz@variables@angleslabelpos, font=\exercice@tikz@variable@fontsize](C,A,B){\exercice@tikz@variables@anglea$^\circ$}
        \tkzLabelAngle[pos=\exercice@tikz@variables@angleslabelpos, font=\exercice@tikz@variable@fontsize](A,B,C){\exercice@tikz@variables@angleb$^\circ$}
    \fi
    \draw(A)--(B)--(C)--cycle;
}
\def\triangleAngles#1{\triangle@angles{#1}}

