\newcommand{\Angle}[1][]{
    \pgfkeys{/tikzAngles/.cd,#1}
    \coordinate(A)at(0,0);
    \coordinate(B1)at(1,0);
    \path(A)([turn]90+\agl:1)coordinate(C1);
    \path(A)--(B1)coordinate[pos=\rightsidelen](B);
    \path(A)--(C1)coordinate[pos=\leftsidelen](C);
    \tkzFillAngle[fill=\clr, size=\aglsize](B,A,C)
    \if\nomark=1\tkzMarkAngle[\clr!50!black,size=\aglsize,mark=none](B,A,C)\fi
    \draw(B)--(A)--(C);
}
\newcommand{\AnglexOy}[1][]{
    \pgfkeys{/tikzAngles/.cd,#1}
    \coordinate[label=\sommetpos:{\mathspoint{\sommetname}}](A)at(0,0);
    \coordinate(B1)at(1,0);
    \path(A)([turn]90+\agl:1)coordinate(C1);
    \path(A)--(B1)coordinate[pos=\rightsidelen](B);
    \path(A)--(C1)coordinate[pos=\leftsidelen](C);
    \path(A)--(B)node[pos=\rightnodepos, \rightsidepos]{\mathspoint{\rightsidename}};
    \path(A)--(C)node[pos=\leftnodepos, \leftsidepos]{\mathspoint{\leftsidename}};
    \tkzFillAngle[fill=\clr, size=\aglsize](B,A,C)
    \if\nomark=1\tkzMarkAngle[\clr!50!black,size=\aglsize,mark=none](B,A,C)\fi
    \draw(B)--(A)--(C);
}
\newcommand{\AngleAOB}[1][]{
    \pgfkeys{/tikzAngles/.cd,#1}
    \coordinate[label=\sommetpos:{\mathspoint{\sommetname}}](A)at(0,0);
    \coordinate(B1)at(1,0);
    \path(A)([turn]90+\agl:1)coordinate(C1);
    \path(A)--(B1)coordinate[pos=\rightsidelen](B);
    \path(A)--(C1)coordinate[pos=\leftsidelen](C);
