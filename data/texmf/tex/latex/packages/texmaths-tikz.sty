\def\txmt@triangles@aca#1{
    \pgfkeys{/TeXMaths/Triangles/ACA/.cd, #1}
    \setlength{\txmt@trianglesACA@tmp@AB}{\texmaths@trianglesACA@longueur}
    \edef\ABpt{\strip@pt\txmt@trianglesACA@tmp@AB} % valeur pure en points
    \pgfmathsetmacro{\ABnum}{\ABpt/28.453} % 1 cm ≈ 28.453 pt

    \coordinate (\texmaths@trianglesACA@nodea) at (\texmaths@trianglesACA@acoord);
    \coordinate (\texmaths@trianglesACA@nodeb) at ($(\texmaths@trianglesACA@nodea) + (\texmaths@trianglesACA@rotate:\ABnum cm)$);
    \pgfmathsetmacro{\BCnum}{\ABnum * sin(\texmaths@trianglesACA@anglea) / sin(180 - \texmaths@trianglesACA@anglea - \texmaths@trianglesACA@angleb)}
    \path(\texmaths@trianglesACA@nodea)--(\texmaths@trianglesACA@nodeb)([turn]\number\numexpr180-\texmaths@trianglesACA@angleb:\BCnum cm) coordinate (\texmaths@trianglesACA@nodec);
}
\def\txmt@triangles@cac#1{
  \pgfkeys{/TeXMaths/Triangles/CAC/.cd, #1}
  \coordinate(\txmt@trianglesCAC@nodea)at(\txmt@trianglesCAC@coorda);
  \coordinate(\txmt@trianglesCAC@nodeb)at($(\txmt@trianglesCAC@nodea)+(\txmt@trianglesCAC@rotate:\txmt@trianglesCAC@longueurab)$);
  \path(\txmt@trianglesCAC@nodeb)--(\txmt@trianglesCAC@nodea)([turn]\number\numexpr\txmt@trianglesCAC@anglea-180:\txmt@trianglesCAC@longueurca)coordinate(\txmt@trianglesCAC@nodec);
}
\pgfkeys{
  /TeXMaths/Triangles/ACA/.cd,
  coordA/.store in=\txmtACAcoordA,
  coordA={0,0},
  AB/.store in=\txmtACAAB,
  AB=5,
  A/.store in=\txmtACAA,
  A=30,
  B/.store in=\txmtACAB,
  B=60
}

\def\txmt@triangles@ccc#1{
  \pgfkeys{/TeXMaths/Triangles/CCC/.cd, #1}
  \coordinate(\txmt@trianglesCCC@nodea)at(\txmt@trianglesCCC@coorda);
  \coordinate(\txmt@trianglesCCC@nodeb)at($(\txmt@trianglesCCC@nodea)+(\txmt@trianglesCCC@rotate:\txmt@trianglesCCC@longueurab)$);

  \setlength{\txmt@trianglesCCC@tmp@AB}{\txmt@trianglesCCC@longueurab}
  \edef\ABpt{\strip@pt\txmt@trianglesCCC@tmp@AB} % valeur pure en points
  \pgfmathsetmacro{\ABnum}{\ABpt/28.453} % 1 cm ≈ 28.453 pt

  \setlength{\txmt@trianglesCCC@tmp@BC}{\txmt@trianglesCCC@longueurbc}
  \edef\BCpt{\strip@pt\txmt@trianglesCCC@tmp@BC} % valeur pure en points
  \pgfmathsetmacro{\BCnum}{\BCpt/28.453} % 1 cm ≈ 28.453 pt

  \setlength{\txmt@trianglesCCC@tmp@CA}{\txmt@trianglesCCC@longueurca}
  \edef\CApt{\strip@pt\txmt@trianglesCCC@tmp@CA} % valeur pure en points
  \pgfmathsetmacro{\CAnum}{\CApt/28.453} % 1 cm ≈ 28.453 pt

  \pgfmathsetmacro{\cosgamma}{(\ABnum^2+\BCnum^2-\CAnum^2)/(2*\ABnum*\BCnum)}
  \pgfmathparse{180-acos(\cosgamma)}
  \global\edef\txt@triangles@gammaturn{\pgfmathresult}
  \path(\txmt@trianglesCCC@nodea)--(\txmt@trianglesCCC@nodeb)([turn]\txt@triangles@gammaturn:\txmt@trianglesCCC@longueurbc)coordinate(\txmt@trianglesCCC@nodec);
}
