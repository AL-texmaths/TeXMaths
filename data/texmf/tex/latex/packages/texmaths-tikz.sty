\end{tikzpicture}}

\def\demidroitegraduee#1#2#3{
    \edef\testa{#1}
    \edef\testb{#2}
    \edef\testd{#3}
    \edef\testc{\number\numexpr\testb-1\relax}
    \begin{tikzpicture}[xscale=\testd,line width=0.8pt]
        \foreach\numa in{0,...,\testa}{
            \coordinate[label={[label distance=10pt]-90:\numa}](X)at(\numa,0);
            \path(X)--+(0,0.2)coordinate(X1);
            \path(X)--+(0,-0.2)coordinate(X2);
            \draw[line width=1.5pt](X1)--(X2);
            \foreach\numb in{1,...,\testc}{
                \path(X)--+(\numb/\testb,0)coordinate(Y);
                \path(Y)--+(0,0.1)coordinate(Y1);
                \path(Y)--+(0,-0.1)coordinate(Y2);
                \draw(Y1)--(Y2);
            }
            \draw[-latex](0,0)--(\testa+1,0);
        }
    \end{tikzpicture}
}
