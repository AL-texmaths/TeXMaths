\newcommand{\tikzSegment}[1][]{%
    
    \pgfkeys{/tikzSegment/.cd,#1}
    \coordinate(O1)at(\tikzSegment@midpos);
    \path(O1)--+(\tikzSegment@angle:\tikzSegment@lenght/2)%
        coordinate[label={[label distance=2pt]\tikzSegment@angle:%
            \expandafter\@firstoftwo\tikzSegment@sommets}](A1);
    \path(O1)--+(180+\tikzSegment@angle:\tikzSegment@lenght/2)%
        coordinate[label={[label distance=2pt]180+\tikzSegment@angle:%
            \expandafter\@secondoftwo\tikzSegment@sommets}](A2);
    \draw[|-|](A1)--(A2);
    
}
