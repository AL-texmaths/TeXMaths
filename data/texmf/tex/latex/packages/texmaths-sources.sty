\makeatletter
\def\newunivar#1{\def#1[##1]{\csname\string#1[##1]\endcsname}}
\def\defunivar#1[#2]{\expandafter\def\csname\string#1[#2]\endcsname}
\def\showsrc#1{\begin{flushright}\hfill{\itshape{Source : \ifcsname\string\src[#1]\endcsname\src[#1]\else inconnue\fi}}\end{flushright}}
% INFOS CODAGES EPREUVES DNB
\newunivar\src
\def\addtofull@src#1#2{%
    \ifx\full@src\undefined
        \edef\full@src{"#1":"#2"}
    \else
        \edef\full@src{\full@src,"#1":"#2"}
    \fi
    }
\def\addtokeys@src#1{%
    \ifx\keys@src\undefined
        \edef\keys@src{#1}
    \else
        \edef\keys@src{\keys@src,#1}
    \fi
}
\def\newsrc[#1]#2{%
    \defunivar\src[#1]{#2}%
    \addtofull@src{#1}{#2}%
    \addtokeys@src{#1}%
    \ifwrite
        \immediate\write\datafile{src|:|#1|:|\unexpanded{#2}}%
    \fi
    }
\makeatother
\ifwrite
    \newwrite\datafile
    \immediate\openout\datafile=\jobname-data.txt\relax
\fi
