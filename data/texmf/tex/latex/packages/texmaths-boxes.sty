% ==========================================
% Boîtes (mdframed) et tableaux (tabularray)
% ==========================================
\global\mdfdefinestyle{rectangle}{%
    backgroundcolor=\mainbgcolor,
    leftmargin=\parindent
}
% -----------------------------
% simple tikz around characters
% -----------------------------
\newcommand{\circled}[2][]{%
    \tikz[baseline=(char.base)] 
    \node[draw,circle,inner sep=1pt,#1] (char) {#2};%
}
\newcommand{\colbox}[2][]{%
    \tikz[baseline=-0.6ex]
    \node[#1, draw, rounded corners]{#2};}%
% --------------------
% Programmes de calcul
% --------------------
\def\programlenght{.5}
\def\program#1#2{%
\begin{minipage}{\programlenght\linewidth}
    \begin{mdframed}
        {\bfseries Programme #1 :}
        \begin{itemize}
            \item Choisir un nombre.
            #2
        \end{itemize}
    \end{mdframed}
\end{minipage}}
% -----------------------
% Tableaux de conversions
% -----------------------
\def\ConvertTable ht=#1;{%
    \noindent
    \begin{tblr}{colspec={*{7}{X[c]}},hlines,vlines,row{2}={ht=#1}}
        km&hm&dam&m&dm&cm&mm\\
        &&&&&&\\
    \end{tblr}\hfil\par
}
\def\ConvertTableSquare ht=#1;{%
    \noindent
    \begin{tblr}{colspec={*{14}{X[c]}},hlines,vlines,row{2}={ht=#1}}
        \SetCell[c=2]{c}km$^2$&&\SetCell[c=2]{c}hm$^2$&&\SetCell[c=2]{c}dam$^2$&&%
        \SetCell[c=2]{c}m$^2$&&\SetCell[c=2]{c}dm$^2$&&\SetCell[c=2]{c}cm$^2$&&\SetCell[c=2]{c}mm$^2$&\\
        &&&&&&&&&&&&&\\
    \end{tblr}\hfil\par
}
\def\ConvertTableCube ht=#1;{%
    \noindent
    \begin{tblr}{colspec={*{12}{X[c]}},hlines,vlines,row{3}={ht=#1}}
        \SetCell[c=3]{c}m$^3$&&&\SetCell[c=3]{c}dm$^3$&&&\SetCell[c=3]{c}cm$^3$&&&\SetCell[c=3]{c}mm$^3$&&\\
        &&&&&\small L&\small dL&\small cL&\small mL&&&\\
        &&&&&&&&&&&\\
    \end{tblr}\hfil\par
}
