\newcommand{\trianglewithangles}[1][]{%
\pgfkeys{/trianglewithangles/.cd,#1}
\begin{scope}[shift={(\xshift,\yshift)}, scale=\scale, rotate=\rotate]
\coordinate[label=\belowleftanglelabelpos:\belowleftanglelabel](B)at(0, 0);
\coordinate[label=\belowrightanglelabelpos:\belowrightanglelabel](C)at(\base,0);
\path(C)--(B)([turn]\belowleftanglevalue:1)coordinate(A1);
\path(B)--(C)([turn]180-\belowrightanglevalue:1)coordinate(A2);
\coordinate[label=\aboveanglelabelpos:\abovelabel](A)at(intersection of B--A1 and C--A2);
\tkzFillAngle[fill=\aboveanglecolor, size=\aboveanglesize](B,A,C)
\tkzFillAngle[fill=\belowleftanglecolor, size=\belowleftanglesize](C,B,A)
\tkzFillAngle[fill=\belowrightanglecolor, size=\belowrightanglesize](A,C,B)
\draw(A)--(B)--(C)--cycle;
\end{scope}
}
