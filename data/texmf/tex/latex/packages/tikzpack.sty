\newcommand{\Angle}[1][]{\tikzset{#1}
\coordinate(A)at(0,0);
\coordinate(B1)at(1,0);
\path(A)([turn]90+\agl:1)coordinate(C1);
\path(A)--(B1)coordinate[pos=\rightsidelen](B);
\path(A)--(C1)coordinate[pos=\leftsidelen](C);
%\path(A)--(B)node[pos=\rightnodepos, \rightsidepos]{$\rightsidename$};
%\path(A)--(C)node[pos=\leftnodepos, \leftsidepos]{$\leftsidename$};
\tkzFillAngle[fill=\clr, size=\aglsize](B,A,C)
\draw(B)--(A)--(C);
}
\newcommand{\AnglexOy}[1][]{\tikzset{#1}
\coordinate[label=\sommetpos:{\sommetname}](A)at(0,0);
\coordinate(B1)at(1,0);
\path(A)([turn]90+\agl:1)coordinate(C1);
\path(A)--(B1)coordinate[pos=\rightsidelen](B);
\path(A)--(C1)coordinate[pos=\leftsidelen](C);
\path(A)--(B)node[pos=\rightnodepos, \rightsidepos]{$\rightsidename$};
\path(A)--(C)node[pos=\leftnodepos, \leftsidepos]{$\leftsidename$};
\tkzFillAngle[fill=\clr, size=\aglsize](B,A,C)
\draw(B)--(A)--(C);
}
\newcommand{\AngleAOB}[1][]{\tikzset{#1}
\coordinate[label=\sommetpos:{\sommetname}](A)at(0,0);
\coordinate(B1)at(1,0);
\path(A)([turn]90+\agl:1)coordinate(C1);
\path(A)--(B1)coordinate[pos=\rightsidelen](B);
\path(A)--(C1)coordinate[pos=\leftsidelen](C);
\path(A)--(B)node[pos=\rightnodepos, \rightsidepos]{\rightsidename};
\path(A)--(B)node[pos=\rightnodepos]{$\times$};
\path(A)--(C)node[pos=\leftnodepos, \leftsidepos]{\leftsidename};
\path(A)--(C)node[pos=\leftnodepos]{$\times$};
\tkzFillAngle[fill=\clr, size=\aglsize](B,A,C)
\draw(B)--(A)--(C);
}

\newcommand{\tstar}[5]{% inner radius, outer radius, tips, rot angle, options
\pgfmathsetmacro{\starangle}{360/#3}
\draw[#5] (#4:#1)
\foreach \x in {1,...,#3}
{ -- (#4+\x*\starangle-\starangle/2:#2) -- (#4+\x*\starangle:#1)
}
-- cycle;
}

\newcommand{\ngram}[4]{% outer radius, tips, rot angle, options
\pgfmathsetmacro{\starangle}{360/#2}
\pgfmathsetmacro{\innerradius}{#1*sin(90-\starangle)/sin(90+\starangle/2)}
\tstar{\innerradius}{#1}{#2}{#3}{#4}
}

