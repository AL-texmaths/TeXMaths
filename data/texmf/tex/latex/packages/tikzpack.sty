\pgfkeys{
    /cycloid/.cd,%
    radius/.store in=\cycloid@radius,%
    radius=1,%
    speed/.store in=\cycloid@speed,%
    speed=0.008,%
    number/.store in=\cycloid@number,%
    number=1,%
    rotate/.store in=\cycloid@rotate,%
    rotate=0,
    }

\newcommand{\cycloid}[1][]{%
    \pgfkeys{/cycloid/.cd,#1}
    \begin{scope}[rotate=\cycloid@rotate]
        \draw[very thick,xshift=20.5,yshift=28.5]%
            plot[domain=-90:-90+\cycloid@number*360,samples=1000]%
            ({\cycloid@speed*(\x) + \cycloid@radius*cos(\x)},{\cycloid@radius*sin(\x)});
    \end{scope}
    }
    \pgfkeys{%
    fiveStar/.cd,%
    r1/.store in=\fiveStar@radiusone,%
    r1=0.375,%
    r2/.store in=\fiveStar@radiustwo,%
    r2=1,%
    rotate/.store in=\fiveStar@rotate,%
    rotate=0,%
    scale/.store in=\fiveStar@scale,%
    scale=1,%
    color/.store in=\fiveStar@color,%
    color=black,%
    fill/.store in=\fiveStar@fillColor,%
    fill=none,%
    xcenter/.store in=\fiveStar@xcenter,%
    xcenter=0,%
    ycenter/.store in=\fiveStar@ycenter,%
    ycenter=0,%
    }
\newcommand{\fiveStar@command}[1][]{%
    \pgfkeys{fiveStar/.cd,#1}
    \begin{scope}[shift={(\fiveStar@xcenter,\fiveStar@ycenter)}]
        \foreach\fiveStar@idAngle in{0,1,...,4}{%
            \coordinate(A\fiveStar@idAngle)at%
                (72*\fiveStar@idAngle-18+\fiveStar@rotate:\fiveStar@scale*\fiveStar@radiusone);
        }
        \foreach\fiveStar@idAngle in{0,1,...,4}{%
            \coordinate(B\fiveStar@idAngle)at%
            (72*\fiveStar@idAngle+18+\fiveStar@rotate:\fiveStar@scale*\fiveStar@radiustwo);
        }
    
        \draw[\fiveStar@color, fill=\fiveStar@fillColor]%
            (A0)--(B0)--(A1)--(B1)--(A2)--(B2)--(A3)--(B3)--(A4)--(B4)--cycle;
    \end{scope}
    }
\def\fiveStar@definition[#1](#2,#3){%
    \pgfkeys{fiveStar/.cd,xcenter=#2,ycenter=#3}
    \fiveStar@command[#1]
}
\newcommand{\fiveStar}[1][]{%
    \fiveStar@definition[#1]%
}
