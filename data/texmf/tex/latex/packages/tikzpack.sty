below left label = A,
below right label/.store in=\belowrightlabel,
below right label = B,
above label/.store in=\abovelabel,
above label = C,
right segment label/.store in=\rightsegmentlabel,
right segment label = above right,
left segment label/.store in=\leftsegmentlabel,
left segment label = above left,
below left label pos/.store in=\belowleftlabelpos,
below left label pos= left,
below right label pos/.store in=\belowrightlabelpos,
below right label pos= right,
above label pos/.store in=\abovelabelpos,
above label pos = above,
below segment label/.store in=\belowsegmentlabel,
below segment label = below,
below lenght/.store in=\belowlenght,
below lenght = 14,
left lenght/.store in=\leftlenght,
left lenght = 7,
right lenght/.store in=\ritghlenght,
right lenght = 13
}
\newcommand{\trianglewithsides}[1][]{
\pgfkeys{/trianglewithsides/.cd,#1}
\begin{scope}[shift={(\xshift,\yshift)}, rotate=\rotate]
    \tkzDefPoint(0,0){\belowleftlabel}
    \tkzDefPoint(\belowlenght,0){\belowrightlabel}

    \tkzInterCC[R](\belowleftlabel,\leftlenght cm)(\belowrightlabel,\ritghlenght cm)
    \tkzGetPoints{\abovelabel}{\abovelabel'}
    \pgfresetboundingbox % removes white space

    \tkzDrawPolygon(\belowleftlabel,\abovelabel,\belowrightlabel)
    \tkzLabelPoints[\belowleftlabelpos](\belowleftlabel)
    \tkzLabelPoints[\abovelabelpos](\abovelabel)
    \tkzLabelPoints[\belowrightlabelpos](\belowrightlabel)

    % lengths (automatic)
    \tkzCalcLength[cm](\belowleftlabel,\belowrightlabel)\tkzGetLength{ABl}
    \tkzCalcLength[cm](\abovelabel,\belowrightlabel)\tkzGetLength{CBl}
    \tkzCalcLength[cm](\belowleftlabel,\abovelabel)\tkzGetLength{ACl}

    \tkzLabelSegment[midway, \belowsegmentlabel](\belowleftlabel,\belowrightlabel){$\pgfmathprintnumber\ABl$ cm}
    \tkzLabelSegment[midway, \rightsegmentlabel](\abovelabel,\belowrightlabel){$\pgfmathprintnumber\CBl$ cm}
    \tkzLabelSegment[midway, \leftsegmentlabel](\belowleftlabel,\abovelabel){$\pgfmathprintnumber\ACl$ cm}
\end{scope}
}
