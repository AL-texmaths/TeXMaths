\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{texmaths-colors}[2018/05/26]
% ========
% PACKAGES
% ========
\RequirePackage{xcolor}
% ========
% COMMANDS
% ========
\newcounter{palette}
\def\newpalette[#1]#2{%
    \stepcounter{palette}
    \expandafter\edef\csname palettes\arabic{palette}\endcsname{#1}
    \newcounter{palette-#1}
    \def\newcolor##1##2{\definecolor{#1-##1}{HTML}{##2}\stepcounter{palette-#1}%
        \expandafter\edef\csname colorID#1-##1\endcsname{\arabic{palette-#1}}%
        \expandafter\global\expandafter\edef\csname color#1\arabic{palette-#1}\endcsname{##1}}%
    #2
    \expandafter\edef\csname palette#1number\endcsname{\arabic{palette-#1}}
}
\newcount\colorindex
\newcount\colortotal
\def\nextcolor{%
    \global\advance\colorindex by 1
    \ifnum\colorindex=\colortotal
        \global\colorindex=0
    \fi
}
\def\initcolor{\colorindex=0\relax}
% DEFAULT MAIN COLORS
\def\currentcolor{gray}
\def\mainbgcolor{white}%
\def\mainthmbgcolor{black!10!white}%
\def\maintblrbgcolor{black!10!white}%
\def\maincodagecolor{black}
