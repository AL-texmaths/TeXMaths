\makeatletter
\def\nbtoalph#1{\@alph{#1}}
\def\nbtoAlph#1{\@Alph{#1}}

\def\write@oe{oe}
\def\thirdcycle@activate@writing{%
    \let\oe\write@oe
    \let\rightarrow\write@rightarrow
}

\def\addtofull@cns@thirdcycle#1#2{%
    \ifx\full@cns@thirdcycle\undefined\edef\full@cns@thirdcycle{"#1":"#2"}\else
        \edef\full@cns@thirdcycle{\full@cns@thirdcycle,"#1":"#2"}
    \fi
    }
\def\addtofull@cmp@thirdcycle#1#2{%
    \ifx\full@cmp@thirdcycle\undefined\edef\full@cmp@thirdcycle{"#1":"#2"}\else
        \edef\full@cmp@thirdcycle{\full@cmp@thirdcycle,"#1":"#2"}
    \fi
    }

\def\deftoks#1{\expandafter\newtoks\csname#1\endcsname}
\def\settoks#1#2{\csname#1\endcsname={#2}}
\def\thetoks#1{\the\csname#1\endcsname}
\def\step#1{#1=\expandafter{\expandafter!\the#1}}
\def\steptoks#1{\expandafter\step\csname#1\endcsname}

\def\newunivar#1{\def#1[##1]{\csname\string#1[##1]\endcsname}}
\def\defunivar#1[#2]{\expandafter\def\csname\string#1[#2]\endcsname}
\def\edefunivar#1[#2]{\expandafter\edef\csname\string#1[#2]\endcsname}

\newunivar\theme
\newunivar\attendu
\newunivar\cns
\newunivar\cmp
\newunivar\total

\newcounter{theme}
\newcounter{attendu}
\newcounter{cns}
\newcounter{cmp}
\newcounter{subcns}
\newcounter{subcmp}

\counterwithin{attendu}{theme}
\counterwithin{cns}{attendu}
\counterwithin{cmp}{attendu}
\counterwithin{subcns}{cns}
\counterwithin{subcmp}{cmp}

\def\endthemes{\edefunivar\total[themes]{\arabic{theme}}}
\def\endattendus{\edefunivar\total[\Alph{theme}]{\arabic{attendu}}}
\def\endcns{\edefunivar\total[\Alph{theme}\arabic{attendu}CNS]{\arabic{cns}}}
\def\endcmp{\edefunivar\total[\Alph{theme}\arabic{attendu}CMP]{\arabic{cmp}}}
\def\endsubcns{\edefunivar\total
    [\Alph{theme}\arabic{attendu}CNS\alph{cns}]{\arabic{subcns}}}
\def\endsubcmp{\edefunivar\total
    [\Alph{theme}\arabic{attendu}CMP\alph{cmp}]{\arabic{subcmp}}}

\def\subcnstotal{\total[\nbtoAlph\themefor\attendufor CNS\nbtoalph\cnsfor]}
\def\subcmptotal{\total[\nbtoAlph\themefor\attendufor CMP\nbtoalph\cmpfor]}

\def\newtheme#1{\stepcounter{theme}\defunivar\theme[\Alph{theme}]{#1}}
\def\newattendu#1{\stepcounter{attendu}\defunivar\attendu
    [\Alph{theme}\arabic{attendu}]{#1}}
\def\newcns#1{
    \stepcounter{cns}
    \deftoks{CNS\Alph{theme}\arabic{attendu}\alph{cns}*occ}
    \settoks{CNS\Alph{theme}\arabic{attendu}\alph{cns}*occ}{}
    \edef\tmpkey{\Alph{theme}\arabic{attendu}\alph{cns}*}
    \defunivar\cns[\tmpkey]{#1}
    \begingroup\thirdcycle@activate@writing\global\addtofull@cns@thirdcycle{\tmpkey}{#1}\endgroup
    }
\def\newcmp#1{
    \stepcounter{cmp}
    \deftoks{CMP\Alph{theme}\arabic{attendu}\alph{cmp}*occ}
    \settoks{CMP\Alph{theme}\arabic{attendu}\alph{cmp}*occ}{}
    \edef\tmpkey{\Alph{theme}\arabic{attendu}\alph{cmp}*}
    \defunivar\cmp[\tmpkey]{#1}
    \begingroup\thirdcycle@activate@writing\global\addtofull@cmp@thirdcycle{\tmpkey}{#1}\endgroup
    }
\def\newsubcns#1{
    \stepcounter{subcns}
    \deftoks{CNS\Alph{theme}\arabic{attendu}\alph{cns}\arabic{subcns}occ}
    \settoks{CNS\Alph{theme}\arabic{attendu}\alph{cns}\arabic{subcns}occ}{}
    \edef\tmpkey{\Alph{theme}\arabic{attendu}\alph{cns}\arabic{subcns}}
    \defunivar\cns[\tmpkey]{#1}
    \begingroup\thirdcycle@activate@writing\global\addtofull@cns@thirdcycle{\tmpkey}{#1}\endgroup
    }
\def\newsubcmp#1{
    \stepcounter{subcmp}
    \deftoks{CMP\Alph{theme}\arabic{attendu}\alph{cmp}\arabic{subcmp}occ}
    \settoks{CMP\Alph{theme}\arabic{attendu}\alph{cmp}\arabic{subcmp}occ}{}
    \edef\tmpkey{\Alph{theme}\arabic{attendu}\alph{cmp}\arabic{subcmp}}
    \defunivar\cmp[\tmpkey]{#1}
    \begingroup\thirdcycle@activate@writing\global\addtofull@cmp@thirdcycle{\tmpkey}{#1}\endgroup
    }

\global\def\usecns[#1]{\steptoks{CNS#1occ}\cns[#1]}
\global\def\usecmp[#1]{\steptoks{CMP#1occ}\cmp[#1]}

\newcounter{occ}

\def\gobone#1{}

\def\loop#1{%
    \ifnum#1=0
    \else
    \edef\tempa{\expandafter\gobone#1}%
    \stepcounter{occ}\loop\tempa\fi
}

\def\@countocc#1{\setcounter{occ}{0}\loop#1\theocc}
\def\countocc#1{\begingroup\edef\temp{\thetoks{#1occ}}\@countocc\temp\endgroup}
