    [\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}]{#1}}
\def\newaut#1{
    \stepcounter{boB@aut}
    \deftoks{AUT\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@aut}occ}
    \settoks{AUT\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@aut}occ}{}
    \edef\tmpkey{\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@aut}}
    \defunivar\aut[\tmpkey]{#1}%
	\ifwrite
		\immediate\write\datafile{\currentcycle_BO_2026|:|aut|:|\tmpkey|:|\unexpanded{#1}}%
	\fi
    }
\def\newobj#1{
    \stepcounter{boB@obj}
    \deftoks{OBJ\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@obj}occ}
    \settoks{OBJ\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@obj}occ}{}
    \edef\tmpkey{\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@obj}}
    \defunivar\obj[\tmpkey]{#1}%
	\ifwrite
		\immediate\write\datafile{\currentcycle_BO_2026|:|obj|:|\tmpkey|:|\unexpanded{#1}}%
	\fi
    }
\def\newpro#1{
    \stepcounter{boB@pro}
    \deftoks{PRO\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@pro}occ}
    \settoks{PRO\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@pro}occ}{}
    \edef\tmpkey{\Alph{boB@theme}\arabic{boB@level}\alph{boB@subtheme}\alph{boB@pro}}
    \defunivar\pro[\tmpkey]{#1}%
	\ifwrite
		\immediate\write\datafile{\currentcycle_BO_2026|:|pro|:|\tmpkey|:|\unexpanded{#1}}%
	\fi
    }

