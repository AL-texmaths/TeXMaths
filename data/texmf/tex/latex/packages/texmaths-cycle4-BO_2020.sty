\def\new@cns#1{
    \stepcounter{fourthcycle@cns}
    \deftoks{CNS\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cns}*occ}
    \settoks{CNS\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cns}*occ}{}
    \edef\tmpkey{\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cns}*}
    \defunivar\fourthcycle@cns[\tmpkey]{#1}%
    \begingroup\fourthcycle@activate@writing\global\addtofull@cns@fourthcycle{\tmpkey}{#1}\endgroup
    \immediate\write\datafile{\currentcycle|:|cns|:|\tmpkey|:|\unexpanded{#1}}%
    }
\def\new@cmp#1{
    \stepcounter{fourthcycle@cmp}
    \deftoks{CMP\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cmp}*occ}
    \settoks{CMP\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cmp}*occ}{}
    \edef\tmpkey{\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cmp}*}
    \defunivar\fourthcycle@cmp[\tmpkey]{#1}%
    \begingroup\fourthcycle@activate@writing\global\addtofull@cmp@fourthcycle{\tmpkey}{#1}\endgroup
    \immediate\write\datafile{\currentcycle|:|cmp|:|\tmpkey|:|\unexpanded{#1}}%
    }
\def\newsubcns#1{
    \stepcounter{fourthcycle@subcns}
    \deftoks{CNS\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cns}\arabic{fourthcycle@subcns}occ}
    \settoks{CNS\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cns}\arabic{fourthcycle@subcns}occ}{}
    \edef\tmpkey{\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cns}\arabic{fourthcycle@subcns}}
    \defunivar\fourthcycle@cns[\tmpkey]{#1}%
    \begingroup\fourthcycle@activate@writing\global\addtofull@cns@fourthcycle{\tmpkey}{#1}\endgroup
    \immediate\write\datafile{\currentcycle|:|cns|:|\tmpkey|:|\unexpanded{#1}}%
    }
\def\newsubcmp#1{
    \stepcounter{fourthcycle@subcmp}
    \deftoks{CMP\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cmp}\arabic{fourthcycle@subcmp}occ}
    \settoks{CMP\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cmp}\arabic{fourthcycle@subcmp}occ}{}
    \edef\tmpkey{\Alph{fourthcycle@theme}\arabic{fourthcycle@attendu}\alph{fourthcycle@cmp}\arabic{fourthcycle@subcmp}}
    \defunivar\fourthcycle@cmp[\tmpkey]{#1}%
    \begingroup\fourthcycle@activate@writing\global\addtofull@cmp@fourthcycle{\tmpkey}{#1}\endgroup
    \immediate\write\datafile{\currentcycle|:|cmp|:|\tmpkey|:|\unexpanded{#1}}%
    }

\def\addtofull@cns@fourthcycle#1#2{%
    \ifx\full@cns@fourthcycle\undefined\edef\full@cns@fourthcycle{"#1":"#2"}\else
        \edef\full@cns@fourthcycle{\full@cns@fourthcycle,"#1":"#2"}
    \fi
    }
\def\addtofull@cmp@fourthcycle#1#2{%
    \ifx\full@cmp@fourthcycle\undefined\edef\full@cmp@fourthcycle{"#1":"#2"}\else
        \edef\full@cmp@fourthcycle{\full@cmp@fourthcycle,"#1":"#2"}
    \fi
    }

\def\new@cns@write#1{\new@cns{#1}\addtofull@cns@fourthcycle{#1}}
\def\new@cmp@write#1{\new@cmp{#1}\addtofull@cmp@fourthcycle{#1}}
\let\newcns\new@cns
\let\newcmp\new@cmp

\global\def\usecns[#1]{\steptoks{CNS#1occ}\fourthcycle@cns[#1]}
\global\def\usecmp[#1]{\steptoks{CMP#1occ}\fourthcycle@cmp[#1]}

\newcounter{fourthcycle@occ}

\def\gobone#1{}

\def\catalogue@loop#1{%
    \ifnum#1=0
    \else
    \edef\tempa{\expandafter\gobone#1}%
    \stepcounter{fourthcycle@occ}\catalogue@loop\tempa\fi
}
\def\@countfourthcycle@occ#1{\setcounter{fourthcycle@occ}{0}\catalogue@loop#1\thefourthcycle@occ}
\def\countocc#1{\begingroup\edef\temp{\thetoks{#1fourthcycle@occ}}\@countfourthcycle@occ\temp\endgroup}
