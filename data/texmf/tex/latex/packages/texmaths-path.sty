% Détection de l'exécutable Python dans .venv (Windows: Scripts, Linux: bin)
\directlua{
  local path = status.filename
  path = path:gsub("\\", "/")
  local root = path:match("(.*/Projects/)")
  local project_root = root .. "TeXMaths/"
  if root then
    local base = root .. "TeXMaths/.venv/"
    local candidates = {
      base .. "Scripts/python.exe",
      base .. "Scripts/python",
      base .. "bin/python",
      base .. "python.exe",
      base .. "python"
    }
    local found = nil
    for _, p in ipairs(candidates) do
      local f = io.open(p, "rb")
      if f then
        f:close()
        found = p
        break
      end
    end
    if found then
      tex.sprint("\\gdef\\texmaths@python@exe{" .. found .. "}")
      tex.sprint("\\gdef\\projects@path@root{" .. root .. "}")
      tex.sprint("\\gdef\\texmaths@path@root{" .. project_root .. "}")
    else
      tex.sprint("\\gdef\\texmaths@python@exe{}")
      tex.sprint("\\gdef\\projects@path@root{}")
      tex.sprint("\\gdef\\texmaths@path@root{}")
      tex.sprint("\\PackageWarning{texmaths-path}{Python executable not found in .venv (checked Scripts and bin)}")
    end
  else
    tex.sprint("\\gdef\\texmaths@python@exe{}")
    tex.sprint("\\gdef\\projects@path@root{}")
    tex.sprint("\\gdef\\texmaths@path@root{}")
    tex.sprint("Chemin */Projects/ introuvable")
  end
}

