\pgfkeys{
  /pdf/.cd,
  scale/.store in = \scale,
  scale = 1,
  /pic/.cd,
  scale/.store in = \scale,
  scale = 1, 
  /gif/.cd,
  scale/.store in = \scale,
    scale = 1
    }
\newcommand{\pdf}[2][]{\pgfkeys{/pdf/.cd,#1}\includegraphics[scale=\scale]{pdf/#2}}
\newcommand{\pic}[2][]{\pgfkeys{/pic/.cd,#1}\includegraphics[scale=\scale]{pic/#2}}
\newcommand{\svg}[2][]{\includesvg[#1]{#2.svg}}
    
